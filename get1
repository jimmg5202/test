var JAVDAY_LOG_PREFIX = "ForwardWidget: JAVDay -";
var JAVDAY_USER_AGENT = "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/98.0.4758.102 Safari/537.36";

function safeJson(data) {
  if (typeof data === "string") {
    try {
      return JSON.parse(data);
    } catch (_) {
      return {};
    }
  }
  return data || {};
}

function ensureArray(v) {
  return Array.isArray(v) ? v : [];
}

function extractCategoryId(url) {
  var match = url.match(/\/([^/]+)\/?$/);
  if (match && match[1]) {
    return match[1].replace(/\/+$/, '');
  }
  
  var parts = url.split('/').filter(function(part) { return part.length > 0; });
  return parts[parts.length - 1] || url.split('/').slice(-2, -1)[0] || 'unknown';
}

function buildPageUrl(baseUrl, sortBy, page) {
  var categoryId = extractCategoryId(baseUrl);
  
  var cleanBaseUrl = baseUrl.replace(/index\.php\//g, '');
  
  var path;
  if (sortBy === "popular") {
    path = "/fiter/by/hits/id/" + categoryId;
  } else {
    path = cleanBaseUrl.indexOf('label/') >= 0 
      ? cleanBaseUrl.replace(/\/page\/\d+\/?$/, '')
      : "/category/" + categoryId;
  }
  
  if (page > 1) {
    return path + "/page/" + page + "/";
  }
  
  return path + "/";
}

function getFullUrl(path) {
  if (path.indexOf("http") === 0) return path;
  
  return "https://javday.app" + path;
}

function getCoverImgSrc(docId, item) {
  var coverElements = Widget.dom.select(docId, ".videoBox-cover");
  if (coverElements.length === 0) return "";
  
  var styleAttr = Widget.dom.attr(coverElements[0], "style");
  
  if (styleAttr) {
    var match = styleAttr.match(/url\(\s*['"]?([^'")]+)['"]?\s*\)/);
    if (match && match[1]) {
      var extractedUrl = match[1];
      
      if (extractedUrl.indexOf("//") === 0) {
        return "https:" + extractedUrl;
      } 
      
      if (extractedUrl.indexOf("http") === 0) {
        return extractedUrl;
      }
      
      return "https://javday.app" + (extractedUrl.indexOf("/") === 0 ? "" : "/") + extractedUrl;
    }
  }
  return "";
}

function extractVideoUrlFromDPlayerScript(scriptContent) {
  if (!scriptContent) return null;
  
  var regexes = [
    /video\s*:\s*{\s*[^}]*url\s*:\s*['"]([^'"]+)['"]/,
    /url\s*:\s*['"]([^'"]+\.m3u8[^'"]*)['"]/
  ];
  
  for (var i = 0; i < regexes.length; i++) {
    var match = scriptContent.match(regexes[i]);
    if (match && match[1]) return match[1];
  }
  
  return null;
}

async function loadPage(params) {
  params = params || {};
  var baseUrl = params.url;
  var sortBy = params.sort_by || "new";
  var page = parseInt(params.page, 10) || 1;
  
  var pagePath = buildPageUrl(baseUrl, sortBy, page);
  var targetUrl = getFullUrl(pagePath);

  try {
    var response = await Widget.http.get(targetUrl, {
      headers: {
        "User-Agent": JAVDAY_USER_AGENT,
        "Referer": "https://javday.app/"
      }
    });

    if (!response || !response.data) {
      console.error(JAVDAY_LOG_PREFIX + " 无法获取页面内容");
      return [];
    }

    var docId = Widget.dom.parse(response.data);
    var videoItems = [];
    var videoBoxes = Widget.dom.select(docId, ".video-wrapper .videoBox");

    for (var index = 0; index < videoBoxes.length; index++) {
      var item = videoBoxes[index];
      var linkElements = Widget.dom.select(item, "a[href]");
      var titleElements = Widget.dom.select(item, ".videoBox-info .title");
      
      if (linkElements.length === 0 || titleElements.length === 0) continue;
      
      var link = Widget.dom.attr(linkElements[0], "href");
      var title = Widget.dom.text(titleElements[0]).trim();
      var imgSrc = getCoverImgSrc(docId, item);

      if (!link || !title) continue;
      
      if (link.indexOf("http") !== 0) {
        link = link.indexOf("//") === 0 
          ? "https:" + link
          : "https://javday.app" + (link.indexOf("/") === 0 ? "" : "/") + link;
      }

      link = link.replace(/([^:]\/)\/+/g, '$1');

      videoItems.push({
        id: String(index) + "|" + link,
        title: title,
        posterUrl: imgSrc,
        backdropUrl: imgSrc,
        link: link,
        description: "来自JAVDay | 排序:" + (sortBy === "new" ? "最新上架" : "人气最高"),
        mediaType: "movie"
      });
    }
    
    Widget.dom.remove(docId);
    return videoItems;
  } catch (error) {
    console.error(JAVDAY_LOG_PREFIX + " 获取视频失败: " + error.message);
    return [];
  }
}

