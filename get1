async function loadDetail(link) {
  try {
    var response = await Widget.http.get(link, {
      headers: {
        "User-Agent": JAVDAY_USER_AGENT,
        "Referer": link
      }
    });

    if (!response || !response.data) {
      console.error(JAVDAY_LOG_PREFIX + " 无法获取详情页内容");
      return [];
    }

    var docId = Widget.dom.parse(response.data);
    var scriptElements = Widget.dom.select(docId, "script");
    var videoUrl = null;
    
    for (var i = 0; i < scriptElements.length; i++) {
      var scriptContent = Widget.dom.text(scriptElements[i]);
      if (scriptContent && scriptContent.indexOf("new DPlayer") >= 0) {
        videoUrl = extractVideoUrlFromDPlayerScript(scriptContent);
        if (videoUrl) break;
      }
    }
    
    if (!videoUrl) {
      var videoElements = Widget.dom.select(docId, "video#J_prismPlayer");
      if (videoElements.length > 0) {
        videoUrl = Widget.dom.attr(videoElements[0], "src");
      }
    }
    
    if (!videoUrl) {
      var sourceElements = Widget.dom.select(docId, "source[src*='.m3u8']");
      if (sourceElements.length > 0) {
        videoUrl = Widget.dom.attr(sourceElements[0], "src");
      }
    }
    
    if (!videoUrl) {
      var videoSrcElements = Widget.dom.select(docId, "video source");
      if (videoSrcElements.length > 0) {
        videoUrl = Widget.dom.attr(videoSrcElements[0], "src");
      }
    }
    
    if (!videoUrl) {
      for (var j = 0; j < scriptElements.length; j++) {
        var scriptContent = Widget.dom.text(scriptElements[j]);
        if (scriptContent && scriptContent.indexOf(".m3u8") >= 0) {
          var m3u8Match = scriptContent.match(/['"](https?:\/\/[^'"]+\.m3u8[^'"]*)['"]/);
          if (m3u8Match && m3u8Match[1]) {
            videoUrl = m3u8Match[1];
            break;
          }
        }
      }
    }
    
    if (!videoUrl) {
      var playerVideoElements = Widget.dom.select(docId, "video[src]");
      if (playerVideoElements.length > 0) {
        videoUrl = Widget.dom.attr(playerVideoElements[0], "src");
      }
    }
    
    if (!videoUrl) {
      var iframeElements = Widget.dom.select(docId, "iframe[src*='player']");
      if (iframeElements.length > 0) {
        videoUrl = Widget.dom.attr(iframeElements[0], "src");
      }
    }

    Widget.dom.remove(docId);

    if (videoUrl) {
      return [{
        title: "",
        videoUrl: videoUrl
      }];
    }

    console.error(JAVDAY_LOG_PREFIX + " 无法找到视频源");
    return [];
  } catch (error) {
    console.error(JAVDAY_LOG_PREFIX + " 加载详情失败: " + error.message);
    return [];
  }
}
